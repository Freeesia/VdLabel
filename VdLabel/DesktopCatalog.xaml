<ui:FluentWindow
    x:Class="VdLabel.DesktopCatalog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
    xmlns:local="clr-namespace:VdLabel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:p="clr-namespace:VdLabel.Properties"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{x:Static p:Resources.DesktopList}"
    Width="{Binding Width, Mode=TwoWay}"
    Height="{Binding Height, Mode=TwoWay}"
    MinHeight="280"
    d:DataContext="{d:DesignInstance local:DesktopCatalogViewModel}"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Closed="FluentWindow_Closed"
    ExtendsContentIntoTitleBar="True"
    Left="{Binding Left, Mode=TwoWay}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Top="{Binding Top, Mode=TwoWay}"
    Topmost="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Default"
    mc:Ignorable="d">
    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="Esc" Command="ApplicationCommands.Close" />
        <KeyBinding Key="Enter" Command="ApplicationCommands.Close" />
    </ui:FluentWindow.InputBindings>
    <ui:FluentWindow.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Close" Executed="CloseCommandBinding_Executed" />
    </ui:FluentWindow.CommandBindings>
    <ListBox
        x:Name="desktops"
        ItemsSource="{Binding Desktops}"
        SelectedItem="{Binding SelectedDesktop}">
        <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
                <UniformGrid Columns="{Binding Columns}" />
            </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
            <DataTemplate DataType="{x:Type local:DesktopViewModel}">
                <Grid>
                    <DockPanel HorizontalAlignment="Center">
                        <emoji:TextBlock
                            MaxHeight="120"
                            Margin="8"
                            HorizontalAlignment="Center"
                            DockPanel.Dock="{Binding Position, Mode=OneWay}"
                            FontSize="28"
                            Text="{Binding Label}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="Wrap" />
                        <Grid>
                            <ui:Image
                                CornerRadius="8"
                                Focusable="False"
                                Source="{Binding ImagePath}" />
                            <ItemsControl
                                Margin="6"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                ItemsSource="{Binding AssignedBadges}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Grid>
                    </DockPanel>
                    <Grid.ContextMenu>
                        <ContextMenu ItemsSource="{Binding BadgeMenuItems}">
                            <ContextMenu.ItemContainerStyle>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Header" Value="{Binding Label}" />
                                    <Setter Property="IsCheckable" Value="True" />
                                    <Setter Property="IsChecked" Value="{Binding IsAssigned, Mode=OneWay}" />
                                    <Setter Property="Command" Value="{Binding ToggleCommand}" />
                                </Style>
                            </ContextMenu.ItemContainerStyle>
                        </ContextMenu>
                    </Grid.ContextMenu>
                </Grid>
            </DataTemplate>
        </ListBox.ItemTemplate>
        <ListBox.ItemContainerStyle>
            <Style BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="ListBoxItem">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Width" Value="280" />
                <Setter Property="Height" Value="280" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border
                                x:Name="Border"
                                Margin="2"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                BorderBrush="Gray"
                                BorderThickness="2"
                                CornerRadius="8">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource ListBoxItemSelectedBackgroundThemeBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ListBox.ItemContainerStyle>
    </ListBox>
</ui:FluentWindow>
